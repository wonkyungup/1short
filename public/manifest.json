{
  "name": "1Short",
  "manifest_version": 3,
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*"
  ],
  "description": "Auto scroll YouTube Shorts, TikTok Reels.",
  "icons": {
    "16": "16x16.png",
    "32": "32x32.png",
    "48": "48x48.png",
    "128": "128x128.png"
  },
  "action": {
    "default_icon": {
      "16": "16x16.png",
      "32": "32x32.png",
      "48": "48x48.png",
      "128": "128x128.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.tiktok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
